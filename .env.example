GROQ_API_KEY=your_groq_key_here
FREE_TIER_ONLY=true

LEGAL_LM_EXTRACTION_MODEL=llama-3.1-8b-instant
LEGAL_LM_REASONING_MODEL=llama-3.3-70b-versatile
LEGAL_LM_EMBEDDING_MODEL=local-hash-lexical
LEGAL_LM_VERIFIER_MODEL=openai/gpt-oss-120b

# Conservative per-run caps. These stop calls before provider usage can run away.
# Match these to your Groq account limits at https://console.groq.com/settings/limits.
LEGAL_LM_MAX_EXTRACTION_REQUESTS=5
LEGAL_LM_MAX_EXTRACTION_INPUT_TOKENS=5000
LEGAL_LM_MAX_REASONING_REQUESTS=6
LEGAL_LM_MAX_REASONING_INPUT_TOKENS=10000
LEGAL_LM_MAX_EMBEDDING_REQUESTS=200
LEGAL_LM_MAX_EMBEDDING_INPUT_TOKENS=300000
LEGAL_LM_MAX_VERIFIER_REQUESTS=5
LEGAL_LM_MAX_VERIFIER_INPUT_TOKENS=7000

# Test/demo mode only. Leave false for real agentic cloud runs.
LEGAL_LM_MOCK_MODELS=false
